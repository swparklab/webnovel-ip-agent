# --- Server ---
HOST=127.0.0.1
PORT=4173

# --- 엔진 선택 ---
# auto  : 키가 있으면 API, 없고 claude CLI가 로그인돼 있으면 구독, 둘 다 없으면 로컬폴백 (기본)
# api   : Anthropic API (토큰 과금, ANTHROPIC_API_KEY 필요)
# cli   : 로컬 Claude Code (Pro/Max 구독 인증) — API 키 불필요/무시
# local : LLM 없이 결정론적 미리보기
#
# ▶ Claude Max 구독으로 쓰려면:  LLM_PROVIDER=cli  로 설정하고
#    터미널에서 `claude` 실행 → 브라우저 로그인(또는 세션 내 /login) 후 서버를 재시작하세요.
#    (주의) ANTHROPIC_API_KEY가 설정돼 있어도 cli 모드에서는 자식 프로세스 환경에서 제거되어
#    구독으로 동작합니다. auto 모드에서는 키가 있으면 API가 우선되니, 구독을 원하면 cli로 고정하세요.
LLM_PROVIDER=auto

# claude 실행 파일 경로 (PATH에 없을 때만 지정). 예: C:\Users\you\AppData\Roaming\npm\claude.cmd
# CLAUDE_BIN=claude

# --- Claude (Anthropic API) ---
# Get a key at https://console.anthropic.com/ and paste it below.
# The key stays on the server and is NEVER sent to the browser.
ANTHROPIC_API_KEY=

# Optional: model tier used by the agent pipeline.
# claude-opus-4-8 (quality) | claude-sonnet-4-6 (balanced) | claude-haiku-4-5-20251001 (fast)
AGENT_MODEL=claude-opus-4-8

# Optional: max output tokens per agent (Draft agent overrides to a higher value).
AGENT_MAX_TOKENS=4096

# Optional: where saved projects are stored.
# DATA_DIR=./data

# Optional: proxy / gateway base url (defaults to https://api.anthropic.com)
# ANTHROPIC_BASE_URL=https://api.anthropic.com
